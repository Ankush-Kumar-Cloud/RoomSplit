# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/roomsplit

# JWT secret key
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT expiry
JWT_EXPIRES_IN=7d

# Backend server port
PORT=5000

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173

# Node environment
NODE_ENV=development