# ─────────────────────────────────────────
# RoomSplit — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# MongoDB connection string
# Atlas example:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/roomsplit?retryWrites=true&w=majority
# Local example:  mongodb://localhost:27017/roomsplit
MONGO_URI=mongodb+srv://roomsplit:RoomSplit123@roomslit.ppv95fs.mongodb.net/?appName=RoomSlit

# JWT secret key — use a long random string in production
JWT_SECRET=roomsplit_2026

# JWT expiry (e.g. 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# Backend server port
PORT=5000

# Frontend URL (used for CORS)
CLIENT_URL=http://localhost:5173

# Node environment: development | production
NODE_ENV=development
